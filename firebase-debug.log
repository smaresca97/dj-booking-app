[debug] [2026-05-11T14:54:07.786Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/dj-booking-app-9931b/rulesets {"name":"projects/dj-booking-app-9931b/rulesets/194c9da0-9727-4ff4-8b77-6796798e8853","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(userId) {\n      return signedIn() && request.auth.uid == userId;\n    }\n\n    function isBootstrapAdminEmail() {\n      return signedIn() && request.auth.token.email in ['smaresca97@gmail.com'];\n    }\n\n    function isAdmin() {\n      return signedIn()\n        && exists(/databases/$(database)/documents/users/$(request.auth.uid))\n        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'\n        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';\n    }\n\n    function isApprovedDjOrAdmin() {\n      return signedIn()\n        && exists(/databases/$(database)/documents/users/$(request.auth.uid))\n        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'\n        && (\n          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dj'\n          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'\n        );\n    }\n\n    function isApprovedVenueOrAdmin() {\n      return signedIn()\n        && exists(/databases/$(database)/documents/users/$(request.auth.uid))\n        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'\n        && (\n          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'venue'\n          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'\n        );\n    }\n\n    match /users/{userId} {\n      allow read: if isOwner(userId) || isAdmin();\n\n      allow create: if isOwner(userId)\n        && (\n          (\n            request.resource.data.role == 'dj'\n            && request.resource.data.status == 'pending'\n          )\n          || (\n            request.resource.data.role == 'venue'\n            && request.resource.data.status == 'pending'\n          )\n          || (\n            isBootstrapAdminEmail()\n            && request.resource.data.role == 'admin'\n            && request.resource.data.status == 'approved'\n          )\n        );\n\n      allow update: if isAdmin()\n        || (\n          isOwner(userId)\n          && request.resource.data.role == resource.data.role\n          && request.resource.data.status == resource.data.status\n        );\n\n      allow delete: if false;\n    }\n\n    match /djProfiles/{djId} {\n      allow read: if true;\n      allow create, update: if isApprovedDjOrAdmin() && (request.auth.uid == djId || isAdmin());\n      allow delete: if false;\n    }\n\n    match /availability/{availabilityId} {\n      allow read: if true;\n      allow create, update: if isApprovedDjOrAdmin()\n        && request.resource.data.djId is string\n        && (request.resource.data.djId == request.auth.uid || isAdmin())\n        && request.resource.data.date is string\n        && request.resource.data.status in ['AVAILABLE', 'NOT_AVAILABLE'];\n      allow delete: if false;\n    }\n\n    match /venueAssignments/{assignmentId} {\n      allow read: if isAdmin()\n        || (\n          isApprovedVenueOrAdmin()\n          && resource.data.venueUserId == request.auth.uid\n        );\n      allow create, update, delete: if isAdmin();\n    }\n\n    match /bookingRequests/{requestId} {\n      allow create: if request.resource.data.djId is string\n        && request.resource.data.djName is string\n        && request.resource.data.clientName is string\n        && request.resource.data.clientPhone is string\n        && request.resource.data.date is string\n        && request.resource.data.from is string\n        && request.resource.data.to is string\n        && request.resource.data.type is string\n        && request.resource.data.place is string\n        && request.resource.data.status == 'pending';\n\n      allow read: if isAdmin()\n        || (\n          isApprovedDjOrAdmin()\n          && resource.data.djId == request.auth.uid\n        );\n\n      allow update: if isAdmin()\n        || (\n          isApprovedDjOrAdmin()\n          && resource.data.djId == request.auth.uid\n          && request.resource.data.djId == resource.data.djId\n          && request.resource.data.status in ['pending', 'accepted', 'rejected']\n        );\n\n      allow delete: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-11T14:54:07.788175Z","metadata":{"services":["cloud.firestore"]}}
