[debug] [2026-05-04T12:20:06.671Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/dj-booking-app-9931b/rulesets {"name":"projects/dj-booking-app-9931b/rulesets/8051361d-f2f3-4e92-96d9-bc6d4726bd41","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(userId) {\n      return signedIn() && request.auth.uid == userId;\n    }\n\n    function isBootstrapAdminEmail() {\n      return signedIn() && request.auth.token.email in ['smaresca97@gmail.com'];\n    }\n\n    function isAdmin() {\n      return signedIn()\n        && exists(/databases/$(database)/documents/users/$(request.auth.uid))\n        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'\n        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';\n    }\n\n    function isApprovedDjOrAdmin() {\n      return signedIn()\n        && exists(/databases/$(database)/documents/users/$(request.auth.uid))\n        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'\n        && (\n          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dj'\n          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'\n        );\n    }\n\n    match /users/{userId} {\n      allow read: if isOwner(userId) || isAdmin();\n\n      allow create: if isOwner(userId)\n        && (\n          (\n            request.resource.data.role == 'dj'\n            && request.resource.data.status == 'pending'\n          )\n          || (\n            isBootstrapAdminEmail()\n            && request.resource.data.role == 'admin'\n            && request.resource.data.status == 'approved'\n          )\n        );\n\n      allow update: if isAdmin()\n        || (\n          isOwner(userId)\n          && request.resource.data.role == resource.data.role\n          && request.resource.data.status == resource.data.status\n        );\n\n      allow delete: if false;\n    }\n\n    match /djProfiles/{djId} {\n      allow read: if true;\n      allow create, update: if isApprovedDjOrAdmin() && (request.auth.uid == djId || isAdmin());\n      allow delete: if false;\n    }\n\n    match /availability/{availabilityId} {\n      allow read: if true;\n      allow create, update: if isApprovedDjOrAdmin()\n        && request.resource.data.djId is string\n        && (request.resource.data.djId == request.auth.uid || isAdmin())\n        && request.resource.data.date is string\n        && request.resource.data.status in ['AVAILABLE', 'NOT_AVAILABLE'];\n      allow delete: if false;\n    }\n\n    match /venueAssignments/{assignmentId} {\n      allow read, create, update, delete: if isAdmin();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-04T12:20:06.576799Z","metadata":{"services":["cloud.firestore"]}}
